	month = jun,
	year = {2026},
	note = {Dataset: huggingface.co/datasets/TimeSeventeen/Polymarket-v1},
}

@misc{ashfaq_nft_2023,
	title = {{NFT} {Wash} {Trading} {Detection}},
	url = {https://arxiv.org/abs/2305.01543},
	abstract = {We develop a graph-based heuristic for detecting wash trading in NFT markets: repeated buy-sell cycles between colluding wallets designed to inflate apparent volume or price. Applied to popular collections, on average 0.14\% of transactions, 0.11\% of wallets, and 0.16\% of tokens are flagged as wash-traded. An unofficial reference implementation is publicly available (github.com/Dreamerryao/nft-wash-trading), making the detection heuristic directly reproducible on other on-chain transaction datasets.},
	publisher = {arXiv},
	author = {Ashfaq, Zulfiqar},
	year = {2023},
	note = {Code: github.com/Dreamerryao/nft-wash-trading},
}
