	url = {https://arxiv.org/abs/2606.04217},
	abstract = {We release Polymarket-v1, a database of 1.20 billion trade records across 1.30 million prediction markets (\$61B nominal volume), reconstructed from on-chain settlement data with 100\% ground-truth aggressor direction. The dataset is released under CC-BY-4.0 and hosted on Hugging Face, enabling independent reproduction of wallet-level informed-trading detection methods (e.g. sign-randomization, composite anomaly screening) whose original implementations are not publicly released.},
